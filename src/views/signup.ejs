<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign Up — Spill the Tea</title>
    <link rel="stylesheet" href="styles.css" />
    <link rel="stylesheet" href="login.css" />
  </head>
  <body class="auth-page">
    <div class="auth-card">
      <div class="auth-card__header">
        <a class="site-logo" href="/">Spill the Tea</a>
        <p class="auth-card__tagline">join the gossip circle 🍵</p>
      </div>

      <form class="auth-form" action="/signup" method="POST">
        <div class="form-group">
          <label class="form-label" for="username">Username</label>
          <input
            class="form-input"
            type="text"
            name="username"
            id="username"
            placeholder="pick a fun name"
            autocomplete="username"
            required
          />
        </div>

        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <input
            class="form-input"
            type="password"
            name="password"
            id="password"
            placeholder="••••••••"
            autocomplete="new-password"
            required
          />
        </div>

        <% if(locals.errors) { %>
        <ul class="form-errors">
          <% locals.errors.forEach(error => { %>
          <li class="form-error"><%= error.msg %></li>
          <% }) %>
        </ul>
        <% } %>

        <button class="btn btn--primary btn--full" type="submit">
          Sign Up
        </button>
      </form>

      <p class="auth-card__footer">
        Already have an account? <a href="/login">Log in here</a>
      </p>
    </div>
  </body>
</html>
